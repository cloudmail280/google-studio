# Google Gemini API (free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Pexels API (free): https://www.pexels.com/api/new/
PEXELS_API_KEY=your_pexels_api_key_here

# Edge-TTS voice (opsional, default id-ID-ArdiNeural untuk Indonesia)
# Lihat daftar lengkap: `edge-tts --list-voices`
TTS_VOICE=id-ID-ArdiNeural

# Video settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_DURATION_SEC=60

# YouTube upload defaults
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
DEFAULT_PRIVACY=unlisted
