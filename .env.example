# === API keys ===
# Gemini (free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Pexels (free): https://www.pexels.com/api/new/
PEXELS_API_KEY=your_pexels_api_key_here

# === TTS ===
# `edge-tts --list-voices` for full list
TTS_VOICE=id-ID-ArdiNeural

# === Video ===
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_DURATION_SEC=60

# === Subtitles ===
# Leave empty to auto-detect system font. Or set path to a .ttf (Bold recommended)
SUBTITLE_FONT_PATH=
SUBTITLE_FONT_SIZE=72
SUBTITLE_STROKE=6
# whisper model: tiny|base|small|medium|large-v3
# 'small' is a good balance for Indonesian. Bigger = more accurate, slower, more RAM.
WHISPER_MODEL=small

# === Music ===
# Folder where you store royalty-free .mp3/.wav files (see README).
MUSIC_DIR=assets/music
MUSIC_VOLUME=0.12

# === Thumbnail ===
THUMBNAIL_FONT_SIZE=120

# === YouTube upload ===
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
DEFAULT_PRIVACY=unlisted
